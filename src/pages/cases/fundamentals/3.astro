  <!-- ── CASE HEADER ───────────────────────────────────────────────────── -->
  <div class="case-header">
    <span class="card-tag">End-of-Life</span>
    <h1>Fundamentals 3 — Samuel Green</h1>
    <p class="case-subtitle">End-of-Life Care in Inpatient Hospice</p>
    <div class="case-meta">
      <span>👤 Samuel Green, 75 years, Jewish Male</span>
      <span>⏱ Scenario: 20 – 25 minutes</span>
