---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const cases = [
  {
    slug: 'fundamentals-1',
    scenario: 'Fundamentals 1',
    patient: 'Alice Morrison · 7 yr · F',
    category: 'Pediatric',
    scenarioTime: '20 – 25 min',
    primaryDx: 'Acute bronchitis',
    secondaryDx: 'Esophageal atresia with gastrostomy',
    challenge: 'Learner assesses and implements care for a pediatric patient whose G-tube feeding has become disconnected while respecting the mother as the expert on the child\'s care.',
  },
  {
    slug: 'fundamentals-2',
    scenario: 'Fundamentals 2',
    patient: 'Bernadette Jackson · 85 yr · F',
    category: 'Older Adult',
    scenarioTime: '20 – 25 min',
    primaryDx: 'Dehydration',
    secondaryDx: 'Urinary retention',
    challenge: 'Learner assesses and implements care for an older adult patient experiencing acute confusion related to a urinary tract infection.',
  },
  {
    slug: 'fundamentals-3',
    scenario: 'Fundamentals 3',
    patient: 'Samuel Green · 75 yr · M',
    category: 'End-of-Life',
    scenarioTime: '20 – 25 min',
    primaryDx: 'Adenocarcinoma bilateral lungs',
    secondaryDx: 'Bone and lymph metastasis',
    challenge: 'Learner provides end-of-life and postmortem care while supporting a grieving family in a manner consistent with the patient and family\'s spiritual beliefs and cultural values.',
  },
  {
    slug: 'fundamentals-4',
    scenario: 'Fundamentals 4',
    patient: 'Jesus Garcia · 28 yr · M',
    category: 'GI / Ostomy',
    scenarioTime: '20 – 25 min',
    primaryDx: 'Dehydration',
    secondaryDx: 'Ulcerative colitis; status postpartial colectomy with transverse colostomy',
    challenge: 'Learner assesses and manages colostomy care while addressing a patient\'s issues with body image and sexuality.',
  },
  {
    slug: 'fundamentals-5',
    scenario: 'Fundamentals 5',
    patient: 'Lisa Rae · 78 yr · F',
    category: 'Patient Safety',
    scenarioTime: '20 – 30 min',
    primaryDx: 'Hypotension',
    secondaryDx: 'Mechanical fall',
    challenge: 'Learner assesses and implements nursing care for a patient at high risk for falls and pressure ulcer development.',
  },
  {
    slug: 'fundamentals-6',
    scenario: 'Fundamentals 6',
    patient: 'Nancy Gilbert · 65 yr · F',
    category: 'Respiratory',
    scenarioTime: '20 – 25 min',
    primaryDx: 'Pneumonia',
    secondaryDx: 'Laryngeal cancer, tracheostomy',
    challenge: 'Learner assesses a patient with moderate respiratory distress and conducts sterile tracheostomy suctioning while maintaining contact isolation precautions.',
  },
  {
    slug: 'fundamentals-7',
    scenario: 'Fundamentals 7',
    patient: 'Carl Rogers · 67 yr · M',
    category: 'Diabetes / Wound Care',
    scenarioTime: '20 – 25 min',
    primaryDx: 'Stage II non-healing ulcer on right heel',
    secondaryDx: 'Diabetes mellitus type I',
    challenge: 'Learner assesses, prioritizes, and manages care for a patient with a non-healing foot ulcer and elevated blood glucose level.',
  },
];
---

<BaseLayout title="Cases" description="Browse all Fundamentals simulation learning cases.">
  <div class="breadcrumb">
    <a href={base}>Home</a>
    <span>›</span>
    <span>Cases</span>
  </div>

  <h1>Simulation Cases</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
    Browse the Fundamentals series of clinical simulation cases covering a range of essential
    nursing competencies across multiple patient populations.
  </p>

  <div class="cases-table-wrap">
    <table class="cases-table">
      <thead>
        <tr>
          <th>Scenario</th>
          <th>Patient</th>
          <th>Category</th>
          <th>Time</th>
          <th>Primary Dx</th>
          <th>Secondary Dx</th>
          <th>Primary Challenge</th>
        </tr>
      </thead>
      <tbody>
        {cases.map((c) => (
          <tr>
            <td><a href={`${base}cases/${c.slug}/`} class="scenario-link">{c.scenario}</a></td>
            <td class="patient-cell">{c.patient}</td>
            <td><span class="card-tag">{c.category}</span></td>
            <td class="time-cell">⏱ {c.scenarioTime}</td>
            <td>{c.primaryDx}</td>
            <td>{c.secondaryDx}</td>
            <td class="challenge-cell">{c.challenge}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</BaseLayout>

<style>
  .cases-table-wrap {
    overflow-x: auto;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
    border: 1px solid var(--color-border);
  }

  .cases-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-surface);
    font-size: 0.9rem;
  }

  .cases-table thead tr {
    background: var(--color-primary);
    color: #fff;
  }

  .cases-table th {
    padding: 0.85rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .cases-table td {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .cases-table tbody tr:last-child td {
    border-bottom: none;
  }

  .cases-table tbody tr:hover {
    background: #f0f4ff;
  }

  .scenario-link {
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
  }

  .patient-cell {
    white-space: nowrap;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .time-cell {
    white-space: nowrap;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .challenge-cell {
    max-width: 280px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
