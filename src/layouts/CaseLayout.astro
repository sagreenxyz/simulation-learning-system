---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  scenario: string;       // e.g. "Fundamentals 1"
  patient: {
    name: string;
    age: string;
    gender: string;
  };
  scenarioTime: string;
  debriefingTime: string;
  concepts: string[];
  skills: string[];
  presentation: string;
  primaryDx: string;
  secondaryDx: string;
  primaryChallenge: string;
  category: string;       // used for the tag pill
}

const {
  scenario, patient, scenarioTime, debriefingTime,
  concepts, skills, presentation,
  primaryDx, secondaryDx, primaryChallenge, category,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={scenario} description={primaryChallenge}>
  <div class="breadcrumb">
    <a href={base}>Home</a>
    <span>›</span>
    <a href={`${base}cases/`}>Cases</a>
    <span>›</span>
    <span>{scenario}</span>
  </div>

  <div class="case-header">
    <span class="card-tag">{category}</span>
    <h1>{scenario}</h1>
    <div class="case-meta">
      <span>👤 {patient.name}, {patient.age}, {patient.gender}</span>
      <span>⏱ Scenario: {scenarioTime}</span>
      <span>💬 Debrief: {debriefingTime}</span>
    </div>
  </div>

  <div class="case-grid">
    <!-- Left column -->
    <div>
      <div class="content-section">
        <h2>Primary Challenge</h2>
        <p class="challenge-text">{primaryChallenge}</p>
      </div>

      <div class="content-section">
        <h2>Scenario Presentation</h2>
        <p>{presentation}</p>
        <div class="dx-block">
          <div class="dx-item">
            <span class="dx-label">Primary diagnosis</span>
            <span>{primaryDx}</span>
          </div>
          <div class="dx-item">
            <span class="dx-label">Secondary diagnosis</span>
            <span>{secondaryDx}</span>
          </div>
        </div>
      </div>

      <div class="content-section">
        <h2>Scenario Concepts</h2>
        <ul class="concept-list">
          {concepts.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </div>

    <!-- Right column -->
    <div>
      <div class="content-section full-height">
        <h2>Scenario Skills</h2>
        <ul class="objective-list">
          {skills.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <div style="margin-top: 2rem;">
    <a href={`${base}cases/`} class="btn btn-back">← Back to Cases</a>
  </div>
</BaseLayout>

<style>
  .case-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .case-grid { grid-template-columns: 1fr; }
  }

  .challenge-text {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-primary-dark);
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    margin: 0;
  }

  .dx-block {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .dx-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .dx-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .concept-list {
    list-style: disc;
    padding-left: 1.25rem;
  }

  .concept-list li {
    margin-bottom: 0.35rem;
    color: var(--color-text);
  }

  .full-height {
    height: 100%;
  }

  .btn-back {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-back:hover {
    background: var(--color-primary-dark);
    text-decoration: none;
  }
</style>
